{
  "hosting": {
    "predeploy": [
      "ng build --configuration production",
      "node copy-index.js"
    ],
    "public": "dist/my-app/browser",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
